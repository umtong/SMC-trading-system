+def test_missing_minute_starts_new_causal_segment() -> None:
+    raw = frame(n=240).drop(index=120).reset_index(drop=True)
+    normalized = normalize_feature_frame(raw.drop(columns=["symbol", "segment_id"]), symbol="BTCUSDT")
+    assert normalized.segment_id.nunique() == 2
+    cfg = StrategyConfig(
+        family=Family.CONTINUATION,
+        abs_return_z=2.0,
+        dislocation_z=0.5,
+        prior_window=50,
+        minimum_prior=20,
+    )
+    enriched = add_causal_features(normalized, cfg)
+    # The first row after the gap has no inherited rolling state.
+    first_after_gap = enriched.index[enriched.segment_id.eq(1)][0]
+    assert pd.isna(enriched.loc[first_after_gap, "abs_return_z"])
+
