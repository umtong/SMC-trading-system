+def test_monthly_returns_use_end_of_day_equity_boundaries() -> None:
+    idx = pd.DatetimeIndex([
+        pd.Timestamp("2025-06-30T23:59:00Z"),
+        pd.Timestamp("2025-07-01T00:00:00Z"),
+        pd.Timestamp("2025-07-31T23:59:00Z"),
+        pd.Timestamp("2025-08-31T23:59:00Z"),
+    ])
+    frame = pd.DataFrame(
+        [
+            {"open": 100.0, "high": 100.0, "low": 100.0, "close": 100.0, "quote_volume": 10_000_000.0, "mark_open": 100.0, "mark_high": 100.0, "mark_low": 100.0, "mark_close": 100.0},
+            {"open": 100.0, "high": 100.2, "low": 99.8, "close": 100.0, "quote_volume": 10_000_000.0, "mark_open": 100.0, "mark_high": 100.2, "mark_low": 99.8, "mark_close": 100.0},
+            {"open": 100.0, "high": 102.0, "low": 99.8, "close": 101.5, "quote_volume": 10_000_000.0, "mark_open": 100.0, "mark_high": 102.0, "mark_low": 99.8, "mark_close": 101.5},
+            {"open": 101.5, "high": 101.5, "low": 101.5, "close": 101.5, "quote_volume": 10_000_000.0, "mark_open": 101.5, "mark_high": 101.5, "mark_low": 101.5, "mark_close": 101.5},
+        ],
+        index=idx,
+    )
+    signals = pd.DataFrame([{
+        "candidate_id": "TEST",
+        "signal_id": "MONTH-END",
+        "symbol": "BTCUSDT",
+        "side": 1,
+        "signal_time": pd.Timestamp("2025-06-30T23:59:30Z"),
+        "entry_time": pd.Timestamp("2025-07-01T00:00:00Z"),
+        "stop_price": 99.0,
+        "target_r": 1.5,
+        "score": 1.0,
+    }])
+    result = simulate(
+        candidate(), signals, {"BTCUSDT": frame, "ETHUSDT": frame.copy()}, empty_funding(),
+        pd.Timestamp("2025-07-01T00:00:00Z"), pd.Timestamp("2025-09-01T00:00:00Z"), zero_cost(),
+    )
+    monthly = result["monthly"]
+    assert monthly.loc[pd.Period("2025-07", freq="M")] > 0
+    assert monthly.loc[pd.Period("2025-08", freq="M")] == pytest.approx(0.0)
