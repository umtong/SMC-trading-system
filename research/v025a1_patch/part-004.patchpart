100, 102, 99.8, 101.5)])
+    funding = empty_funding()
+    # Negative funding would pay a newly opened long, but minute data cannot prove
+    # the order existed before the exact snapshot.  Do not book the credit.
+    funding["BTCUSDT"] = pd.DataFrame({"timestamp": [btc.index[1]], "funding_rate": [-0.01]})
+    result = simulate(candidate(), pd.DataFrame([signal(1, 99.0)]), {"BTCUSDT": btc, "ETHUSDT": btc.copy()}, funding, btc.index[0], btc.index[-1] + pd.Timedelta(minutes=1), zero_cost())
+    assert result["ledger"].iloc[0]["funding_pnl"] == pytest.approx(0.0)
