+def test_funding_at_minute_boundary_uses_mark_open_not_future_mark_close() -> None:
+    btc = bars_for([(100, 100, 100, 100), (100, 100.2, 99.8, 100), (100, 100.2, 99.8, 100), (100, 102, 99.8, 101.5)])
+    # Make the funding minute close absurdly different.  The payment at the
+    # exact minute boundary must remain based on the observable mark open.
+    btc.loc[btc.index[2], "mark_open"] = 100.0
+    btc.loc[btc.index[2], "mark_close"] = 1_000.0
+    eth = btc.copy()
+    funding = empty_funding()
+    funding["BTCUSDT"] = pd.DataFrame({"timestamp": [btc.index[2]], "funding_rate": [0.01]})
+    result = simulate(candidate(), pd.DataFrame([signal(1, 99.0)]), {"BTCUSDT": btc, "ETHUSDT": eth}, funding, btc.index[0], btc.index[-1] + pd.Timedelta(minutes=1), zero_cost())
+    row = result["ledger"].iloc[0]
+    expected = -float(row["quantity"]) * 100.0 * 0.01
+    assert row["funding_pnl"] == pytest.approx(expected)
+
