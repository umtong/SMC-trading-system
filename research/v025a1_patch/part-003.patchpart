 = aggregate_5s(events).iloc[0]
+    assert bar["count"] == 2
+    assert bar["quote"] == pytest.approx(200.0)
+    assert bar["signed_quote"] == pytest.approx(200.0)
+
+
+def test_stop_uses_full_completed_raid_minute_extreme_available_at_decision() -> None:
+    events = synthetic_short_events()
+    # Event confirmation happens at 00:05:10, while the completed minute's
+    # subsequently observed high is 101.75.  The order is not sent until after
+    # minute close, so the stop must use that known full-minute extreme.
+    signal = find_exhaustion_signal(context(minute_high=101.75), candidate(), events)
+    assert signal is not None
+    assert signal.raid_extreme == pytest.approx(101.75)
+    assert signal.stop_price == pytest.approx(101.85)
