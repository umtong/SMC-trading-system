+def test_gap_beyond_mark_liquidation_is_not_reported_as_ordinary_stop() -> None:
+    btc = bars_for([(100, 100, 100, 100), (100, 100.05, 99.95, 100), (60, 61, 59, 60)])
+    # The strategy stop is closer than liquidation, but a discontinuous mark gap
+    # opens beyond both.  Fail closed as a liquidation rather than an executable
+    # ordinary stop at the impossible skipped level.
+    btc.loc[btc.index[0], "quote_volume"] = 100_000_000.0
+    btc.loc[btc.index[2], ["mark_open", "mark_high", "mark_low", "mark_close"]] = [60, 61, 59, 60]
+    result = simulate(candidate(), pd.DataFrame([signal(1, 99.9)]), {"BTCUSDT": btc, "ETHUSDT": btc.copy()}, empty_funding(), btc.index[0], btc.index[-1] + pd.Timedelta(minutes=1), zero_cost())
+    row = result["ledger"].iloc[0]
+    assert row["exit_reason"] == "gap_liquidation"
+    assert row["liquidation_fee"] > 0
+    assert result["metrics"]["liquidations"] == 1
+    assert result["metrics"]["final_equity_mtm"] >= 0
+
