# This repository intentionally publishes only the current EasyChart/SMC work.
# Everything else remains available locally but is not part of the Git history.
/*

!/.gitignore
!/README.md
!/MAIN_AGENT_STATE.md
!/pyproject.toml

# Current strategy package.
!/src/
/src/*
!/src/ictbt/
/src/ictbt/*
!/src/ictbt/__init__.py
!/src/ictbt/easychart_v0/

# Current strategy tests.
!/tests/
/tests/*
!/tests/easychart_v0/

# Reproducible comparison scripts only.
!/scripts/
/scripts/*
!/scripts/analyze_easychart_v0_2_winrate.py
!/scripts/compare_easychart_delivery_entry_arms.py
!/scripts/compare_easychart_v04_scene_families.py
!/scripts/compare_easychart_v05_liquidity_delivery.py
!/scripts/compare_easychart_v06_owned_m15_overlap_stops.py
!/scripts/compare_easychart_v07_scene_families.py

# Current policy, formulas, reconstruction, and economically relevant reports.
!/artifacts/
/artifacts/*
!/artifacts/strategy_composition_2026_07_18/
/artifacts/strategy_composition_2026_07_18/*
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_STRATEGY_RECONSTRUCTION_V2.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_V0_POLICY_DECISION_DRAFT.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_V0_OHLCV_FORMULA_CONTRACT.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_V0_3_ENTRY_ARM_COMPARISON_KO.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_V0_5_LIQUIDITY_DELIVERY_COMPARISON_KO.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_OB_V0_6_OWNED_M15_OVERLAP_STOP_COMPARISON_KO.md
!/artifacts/strategy_composition_2026_07_18/EASYCHART_SR_FLIP_FVG_V0_7_COMPARISON_KO.md

# Compact reference results. Large window-level outputs remain local.
!/results/
/results/*
!/results/easychart_delivery_entry_comparison_v03_fixed/
/results/easychart_delivery_entry_comparison_v03_fixed/*
!/results/easychart_delivery_entry_comparison_v03_fixed/summary.json
!/results/easychart_delivery_entry_comparison_v03_fixed/trade_ledger.csv
!/results/easychart_v05_m15_m5_liquidity_delivery/
!/results/easychart_v06_owned_m15_overlap_stops/
/results/easychart_v06_owned_m15_overlap_stops/window_*/
!/results/easychart_v07_scene_families/

# EasyChart source captions and their corpus manifest.
!/data/
/data/*
!/data/easychart_captions/
!/data/easychart_captions/yt_dlp/
!/registrations/
/registrations/*
!/registrations/easychart_caption_corpus_2026_07.json

# Generated/cache files inside included directories.
**/__pycache__/
*.py[cod]
.pytest_cache/
.pytest_tmp/
pytest_temp_*/
*.sqlite
*.sqlite3
*.sqlite3-*
*.db
*.mp4
*.tar.gz
*.zip

